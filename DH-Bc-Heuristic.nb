                RowBox[{"c", 
                 RowBox[{"(", 
                  RowBox[{"1", "-", 
                   RowBox[{"2", "/", 
                    RowBox[{"(", 
                    RowBox[{"n", 
                    RowBox[{"(", 
                    RowBox[{"n", "-", "1"}], ")"}]}], ")"}]}]}], ")"}], 
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"n", "^", "2"}], "-", 
                   RowBox[{"8", "n"}], "+", "20", "-", 
                   RowBox[{"16", "/", "n"}]}], ")"}]}]}], ")"}]}], "+", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"Exp", "[", 
                 RowBox[{
                  RowBox[{"-", "4"}], "\[Mu]"}], "]"}], "/", 
                RowBox[{"(", 
                 RowBox[{"B", "*", 
                  RowBox[{"n", "^", "2"}]}], ")"}]}], ")"}], 
              RowBox[{"(", 
               RowBox[{"n", "+", 
                RowBox[{"n", 
                 RowBox[{"(", 
                  RowBox[{"n", "-", "1"}], ")"}], "q1"}]}], ")"}]}], "-", 
             RowBox[{
              RowBox[{"(", 
               RowBox[{
                RowBox[{"Exp", "[", 
                 RowBox[{
                  RowBox[{"-", "8"}], "\[Mu]"}], "]"}], "/", 
                RowBox[{"(", 
                 RowBox[{"2", "B", "*", 
                  RowBox[{"n", "^", "2"}]}], ")"}]}], ")"}], 
              RowBox[{"(", 
               RowBox[{
                RowBox[{"(", 
                 RowBox[{"n", "+", "2"}], ")"}], "+", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{
                   RowBox[{"n", "^", "2"}], "+", 
                   RowBox[{"4", "n"}], "-", "8"}], ")"}], "q1"}], "+", 
                RowBox[{
                 RowBox[{"(", 
                  RowBox[{"n", "-", "2"}], ")"}], 
                 RowBox[{"(", 
                  RowBox[{"n", "-", "3"}], ")"}], "q2"}]}], ")"}]}]}], 
            "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"q1", "=", "q1novo"}], ";", "\[IndentingNewLine]", 
          RowBox[{"q2", "=", "q2novo"}], ";", "\[IndentingNewLine]", 
          RowBox[{"\[Sigma]2", "=", "\[Sigma]2novo"}], ";", 
          "\[IndentingNewLine]", 
          RowBox[{"c", "=", "cnovo"}]}], "\[IndentingNewLine]", ",", 
         RowBox[{"{", 
          RowBox[{"t", ",", "1", ",", "\[Tau]"}], "}"}]}], "]"}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"\[CapitalLambda]1", "=", 
        RowBox[{"Limit", "[", 
         RowBox[{"\[Sigma]2", ",", 
          RowBox[{"B", "\[Rule]", "\[Infinity]"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"\[CapitalLambda]2", "=", 
        RowBox[{"Limit", "[", 
         RowBox[{
          RowBox[{"B", "*", "\[Sigma]2"}], ",", 
          RowBox[{"B", "\[Rule]", "0"}]}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"k", "=", "1"}], ";", "\[IndentingNewLine]", 
       RowBox[{"\[Delta]q", "=", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{
           RowBox[{"qmin", "/", "qeq"}], "-", "1"}], ")"}], "/", 
         RowBox[{"(", 
          RowBox[{
           RowBox[{"n", " ", 
            RowBox[{"Exp", "[", 
             RowBox[{"4", "\[Mu]"}], "]"}], 
            RowBox[{"(", 
             RowBox[{"k", "-", "1"}], ")"}]}], "+", 
           RowBox[{"(", 
            RowBox[{"n", "-", "1"}], ")"}]}], ")"}]}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"\[CapitalLambda]2", "/", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"(", 
            RowBox[{"\[Delta]q", "+", 
             RowBox[{"Sqrt", "[", "\[CapitalLambda]1", "]"}]}], ")"}], "^", 
           "2"}], "-", "\[CapitalLambda]1"}], ")"}]}]}]}], 
     "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
