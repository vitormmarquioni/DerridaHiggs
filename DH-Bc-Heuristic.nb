     RowBox[{"Using", " ", "'"}]}], 
    RowBox[{"floor", "'"}], " ", "function", " ", "when", " ", "calculating", 
    " ", 
    RowBox[{"\"\<transition time\>\"", "**", "**", "**"}]}], "******)"}], 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
